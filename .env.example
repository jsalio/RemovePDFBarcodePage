# Copia este archivo a .env y completa los valores reales.
# El .env NO debe subirse a control de versiones.

# URL base del servidor, sin slash final. Ej: https://miservidor.prodoctivity.com
PD_BASE_URL=

# Credenciales
PD_USERNAME=
PD_PASSWORD=
PD_ORGANIZATION=
PD_API_KEY=
PD_API_SECRET=

# Rutas del API (ajustar si difieren en tu instalación)
PD_LOGIN_PATH=/svc/api/login
PD_SEARCH_PATH=/svc/api/documents/search

# Opcional: tamaño de página para la búsqueda
PD_PAGE_SIZE=50

# Opcional: IDs de tipo de documento separados por coma (también puede pasarse
# por CLI con --document-type-ids, que tiene prioridad sobre esta variable)
PD_DOCUMENT_TYPE_IDS=

# Valor del código de barras que identifica la primera página a eliminar
# (usado por process_documents.py)
PD_BARCODE_VALUE=EXP-001
